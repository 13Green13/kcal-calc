{
  "name": "kcal-calc",
  "version": "0.1.1",
  "description": "Obsidian plugin that annotates ingredient lines with kcal values from USDA FoodData Central.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "nutrition",
    "kcal",
    "usda"
  ],
  "author": "13Green13 <purple13purp13@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.28.1",
    "obsidian": "^1.5.12",
    "typescript": "^5.5.3"
  }
}
